# Copy to .env and fill in your values. Never commit .env.

# Linq Partner API
LINQ_API_KEY=your_linq_api_key_here
LINQ_FROM_NUMBER=+1XXXXXXXXXX        # your registered Linq phone number
LINQ_WEBHOOK_SECRET=your_webhook_signing_secret_here

# The analyst's personal number (the only person who texts the bot)
USER_PHONE_NUMBER=+1XXXXXXXXXX

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: path to SQLite DB (defaults to linqsight.db in cwd)
# DB_PATH=linqsight.db
